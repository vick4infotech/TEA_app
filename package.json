{
  "name": "tea-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "predev": "node scripts/prepare-env.js && prisma generate && prisma db push",
    "build": "node scripts/prepare-env.js && prisma generate && next build",
    "start": "node scripts/prepare-env.js && prisma generate && prisma db push && npm run db:seed && next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "db:setup": "node scripts/prepare-env.js && prisma generate && prisma db push && npm run db:seed",
    "postinstall": "node scripts/prepare-env.js && prisma generate",
    "setup": "npm install --registry=https://registry.npmjs.org/ && npm run db:setup",
    "serve": "next start",
    "start:docker": "sh scripts/docker-entrypoint.sh"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "date-fns": "^4.1.0",
    "jose": "^5.9.6",
    "lucide-react": "^0.468.0",
    "next": "^14.2.18",
    "papaparse": "^5.4.1",
    "prisma": "^5.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.18",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15"
  }
}
